# .env.unreal.ps1 — Unreal Engine analysis config for PowerShell scripts
#
# This file is READ AUTOMATICALLY by the arch*.ps1 scripts as ".env"
# (they parse key=value format, same as bash .env).
# You can also rename/copy this to ".env" in your repo root.
#
# https://github.com/rivaborn/LocalLLM_Code_Analysis

CLAUDE1_CONFIG_DIR=
CLAUDE2_CONFIG_DIR=

CLAUDE_MODEL=haiku
CLAUDE_MAX_TURNS=1
CLAUDE_OUTPUT_FORMAT=text

# ── Local LLM backend (LLMConfig gateway) ──
# Selects which backend the doc-generation calls use. Currently the local
# Ollama server (qwen3.6:27B -- a thinking model whose reasoning is kept OUT of
# the doc via the native /api/chat path). Set LLM_BACKEND=vllm for the fast vLLM
# gateway, or LLM_BACKEND=claude to fall back to the claude CLI (CLAUDE_* keys).
# NOTE: Read-EnvFile does NOT strip trailing inline comments -- keep each value
# on its own line with no '#' after it.
# LLM_BACKEND: ollama | vllm | claude
LLM_BACKEND=ollama
# LLM_HOST: the LLMConfig box (static IP)
LLM_HOST=192.168.1.40
# LLM_ENDPOINT: full URL override; else host:11430 (vllm) / host:11434 (ollama)
#LLM_ENDPOINT=
# LLM_PORT: ollama backend only (vllm always uses the 11430 gateway)
LLM_PORT=11434
# LLM_DEFAULT_MODEL: backend-specific id -- Ollama tags use ':' (qwen3.6:27B);
# vLLM served-names use '-' (qwen3-coder-30b). Must match LLM_BACKEND.
LLM_DEFAULT_MODEL=qwen3.6:27B
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=1000
# LLM_TIMEOUT: seconds; covers a cold gateway auto-load
LLM_TIMEOUT=900
# LLM_NUM_CTX: ollama /api/chat only (must be >0 to use the native path that
# separates reasoning); ignored by the vLLM gateway. Sizes the KV cache, so lower
# it until model+KV leaves a few GB free on the GPU (intermittent connect/timeout
# errors mid-run = the card OOM-crashing llama-server). NOTE: the run_pipeline
# pre-flight gateway load uses the model's BAKED Modelfile num_ctx, not this value
# -- to keep them consistent, bake a context-matched Ollama tag (FROM <model> +
# PARAMETER num_ctx N, e.g. <model>-64k) and set LLM_DEFAULT_MODEL to it.
LLM_NUM_CTX=32768
# LLM_THINK: ollama only -- true routes reasoning to message.thinking instead of
# polluting the doc content. Needed for thinking models like qwen3.6:27B. The
# token-budget floor in llm_core.ps1 keeps room for content after reasoning.
LLM_THINK=true
# DEGRADE_FALLBACK_MODEL: local backends only -- when the local model hits the degrade
# path on a file (thinking-exhaustion / empty / context overflow), escalate THAT file to
# this claude model (full payload) instead of emitting a truncated doc, then continue
# locally. Needs a valid CLAUDE*_CONFIG_DIR + claude CLI. Empty = disabled.
DEGRADE_FALLBACK_MODEL=

# NOTIFY_URL: optional. run_pipeline.ps1 / run_batch.ps1 POST a push notification at
# each pipeline section (start, every stage, complete/failed). Set to an ntfy topic URL
# (e.g. https://ntfy.sh/your-topic or a self-hosted https://ntfy.host/topic) or any
# webhook that accepts a plain-text body. The message is the body; Title/Priority/Tags
# go as headers (ntfy convention). Empty = notifications disabled. Best-effort: a POST
# failure warns but never breaks the run.
NOTIFY_URL=
# NOTIFY_PROGRESS_INTERVAL: seconds between progress-line heartbeats POSTed to
# NOTIFY_URL during Pass 1 / Pass 2 -- the live "PROGRESS: x/y skip=.. fail=.. eta=.."
# line, so a long unattended run reports in periodically. Default 900 (15 min).
NOTIFY_PROGRESS_INTERVAL=900
# ETA_MIN_PER_FILE: minutes-per-file for the pre-run ETA estimate that run_pipeline
# (per subsystem) and run_batch (whole run) print + notify at start. Default 3.3
# (basis: a 27B thinking model at Jobs=1 on a local 3090 ~= 3.1-3.3 min/file).
ETA_MIN_PER_FILE=3.3

JOBS=8
MAX_RETRIES=2
RETRY_DELAY=5

# ── Unreal Engine specifics ──

PRESET=unreal

CODEBASE_DESC="Unreal Engine source (Epic Games). Large-scale C++ game engine: Core (memory/containers/math/logging), CoreUObject (UObject reflection/GC/CDO), Engine (actors/components/world), Renderer (deferred shading, RHI abstraction over D3D12/Vulkan/Metal), PhysicsCore/Chaos, AudioMixerCore, AIModule, GameplayAbilities (GAS), Slate/UMG UI, NetworkCore (replication/RPCs). UHT generates reflection code. Blueprint VM, delegates, TWeakObjectPtr, FName/FText/FString, UBT build system."

INCLUDE_EXT_REGEX=\.(cpp|h|hpp|cc|cxx|inl|cs)$
EXCLUDE_DIRS_REGEX=[/\\](\.git|architecture|Binaries|Build|DerivedDataCache|Intermediate|Saved|\.vs|ThirdParty|GeneratedFiles|AutomationTool)([/\\]|$)

BUNDLE_HEADERS=1
MAX_BUNDLED_HEADERS=8

# Truncate very large UE headers (Actor.h etc can be 5000+ lines)
MAX_FILE_LINES=3000

# UE is huge — chunked overview is essential
CHUNK_THRESHOLD=1500
